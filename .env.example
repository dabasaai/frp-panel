PORT=9090
# 緊急後門密碼（SSO 故障時用；留空可停用密碼登入）
PANEL_PASSWORD=changeme

# --- Digitalent SSO 統一認證 ---
AUTH_SERVER=https://auth.digitalent.cc
# 本面板對外網址；須與 auth 平台後台註冊的 app url 同 host。
# 設定後：使用者要在後台看得到此 app 才放行（群組授權由後台管理）。留空＝任何登入者皆可。
AUTH_APP_URL=https://frp.digitalent.tw
FRP_SERVER_ADDR=your_server_domain
FRP_SERVER_PORT=7000
FRP_AUTH_TOKEN=your_frps_auth_token
DOMAINS=your_domain.com
# 選填：填入 frps Admin API 可查看所有隧道狀態
#FRPS_ADMIN_URL=http://127.0.0.1:7500
#FRPS_ADMIN_USER=admin
#FRPS_ADMIN_PASS=
