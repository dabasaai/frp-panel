# frpc 主設定檔 — FRP Panel 用
# 複製為 frpc.toml 後由 setup.sh 自動填入

serverAddr = "gsct.tw"
serverPort = 7000
auth.method = "token"
auth.token = "77890a0978d7f965982d20de2f7d3fc2"

log.to = "console"
log.level = "info"

# 啟用 webServer 供 frpc reload 使用
webServer.addr = "127.0.0.1"
webServer.port = 7400

# 載入 conf.d/ 內所有 proxy 設定
includes = ["./conf.d/*.toml"]
